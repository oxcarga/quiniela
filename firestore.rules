rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Matches: public read, admin-only write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Users: authenticated read, own write only
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Booster registry: one doc per match-day, written only by the
      // toggleBooster Cloud Function (admin SDK). Owner may read.
      match /boosterDays/{day} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Predictions: authenticated read, own write only before kickoff.
    // The `boosted` flag is managed exclusively by the toggleBooster
    // Cloud Function, and `pointsEarned` exclusively by scoreMatch —
    // clients may neither set either field on create nor change it on update.
    match /predictions/{userId}/matches/{matchId} {
      function matchData() {
        return get(/databases/$(database)/documents/matches/$(matchId)).data;
      }
      // A match is no longer "upcoming" once it has kicked off OR an admin has
      // marked it finished — mirrors getEffectiveStatus() on the client.
      function matchStarted() {
        return request.time >= matchData().kickoffAt
               || matchData().status == 'finished';
      }

      // Single-doc reads: a user can always read their own prediction; another
      // user's prediction is only readable once the match is no longer upcoming,
      // so upcoming picks can't be peeked at (e.g. via the network) before lock.
      allow get: if request.auth != null
                 && (request.auth.uid == userId || matchStarted());
      // Collection queries: only over your own predictions. (Cross-document
      // checks can't be evaluated for a `list`, so others' picks must be read
      // one match at a time via the `get` rule above.)
      allow list: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.time < matchData().kickoffAt
                    && request.resource.data.get('boosted', false) == false
                    && request.resource.data.get('pointsEarned', null) == null;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.time < matchData().kickoffAt
                    && request.resource.data.get('boosted', false) == resource.data.get('boosted', false)
                    && request.resource.data.get('pointsEarned', null) == resource.data.get('pointsEarned', null);
    }

    // Leaderboard: public read, written only by Cloud Functions (admin SDK)
    match /leaderboard/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Login codes: written and verified only by the server (Admin SDK), which
    // bypasses these rules. Clients must never read or write them — a leaked
    // code hash would undermine the OTP login.
    match /loginCodes/{email} {
      allow read, write: if false;
    }
  }
}
